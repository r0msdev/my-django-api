# Copy this file to .env and fill in values before running the project.
# .env is already in .gitignore and should never be committed.

# Settings module to load. Use dev for local development, prod for production.
# manage.py defaults to app.settings.dev
# wsgi.py / asgi.py default to app.settings.prod
DJANGO_SETTINGS_MODULE=app.settings.dev

# Required in production. Generate with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# In dev this is optional — dev.py has a built-in insecure fallback.
DJANGO_SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hosts, e.g. localhost,127.0.0.1,example.com
# In dev this is ignored (ALLOWED_HOSTS = ['*'])
DJANGO_ALLOWED_HOSTS=
